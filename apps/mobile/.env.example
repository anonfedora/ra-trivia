# API Configuration
# Replace with your local machine IP address for physical device testing
EXPO_PUBLIC_API_URL=http://localhost:4000/api

# Examples for different platforms:
# For iOS simulator: EXPO_PUBLIC_API_URL=http://localhost:4000/api
# For Android emulator: EXPO_PUBLIC_API_URL=http://10.0.2.2:4000/api
# For physical device: EXPO_PUBLIC_API_URL=http://YOUR_IP_ADDRESS:4000/api
