    "build:migrate": "prisma generate --schema=../../packages/database/prisma/schema.prisma && prisma migrate deploy --schema=../../packages/database/prisma/schema.prisma && tsc",
    "start": "node dist/index.js",
    "migrate": "prisma migrate deploy --schema=../../packages/database/prisma/schema.prisma",
    "migrate:dev": "prisma db push --schema=../../packages/database/prisma/schema.prisma",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
