{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "outDir": "./dist",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "database": [
                "../../packages/database/src/index.ts"
            ],
            "database/*": [
                "../../packages/database/src/*"
            ]
        }
    },
    "include": [
        "src/**/*"
    ]
}