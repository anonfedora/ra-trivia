generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(uuid())
  email     String        @unique
  name      String
  password  String
  role      Role          @default(CANDIDATE)
  userType  UserType      @default(AMBASSADOR_RANK_EXAMS)
  church    String?
  association String?
  emailVerified Boolean   @default(false)
  emailVerificationTokenHash String?
  emailVerificationTokenExpiresAt DateTime?
  emailOtpHash String?
  emailOtpExpiresAt DateTime?
  passwordResetTokenHash String?
  passwordResetTokenExpiresAt DateTime?
  uploadedById String?     // Track which admin uploaded this candidate
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  sessions  QuizSession[]
  quizzes   Quiz[]        @relation("QuizCreator")
  auditLogs UserTypeAuditLog[]
  supportMessages SupportMessage[]
  refreshTokens RefreshToken[]
  notifications Notification[]
  uploadedBy User?         @relation("CandidateUploader", fields: [uploadedById], references: [id])
  uploadedCandidates User[] @relation("CandidateUploader")
}

model Question {
  id            String   @id @default(uuid())
  text          String
  optionA       String?
  optionB       String?
  optionC       String?
  optionD       String?
  correctOption String
  format        QuestionFormat @default(MULTIPLE_CHOICE)
  questionType  UserType @default(AMBASSADOR_RANK_EXAMS)
  quizId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  quiz          Quiz     @relation(fields: [quizId], references: [id])
}

enum QuestionFormat {
  MULTIPLE_CHOICE
  FILL_IN_THE_GAP
}

enum ResultsDisplayMode {
  DETAILED
  STUDY
  SCORE_ONLY
}

model Quiz {
  id                 String             @id @default(uuid())
  title              String
  duration           Int
  isActive           Boolean            @default(false)
  retakeLimit        Int?               @default(2)
  passMark           Float?             @default(50) // Default pass mark percentage
  examCode           String?
  startDate          DateTime?
  endDate            DateTime?
  resultsDisplayMode ResultsDisplayMode @default(DETAILED)
  createdById        String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  questions          Question[]
  sessions           QuizSession[]
  createdBy          User?              @relation("QuizCreator", fields: [createdById], references: [id])
  supportMessages    SupportMessage[]
}

model QuizSession {
  id               String    @id @default(uuid())
  startTime        DateTime  @default(now())
  endTime          DateTime?
  score            Float?
  answers          Json?
  userId           String
  quizId           String
  resultReleasesAt DateTime?
  emailSent        Boolean   @default(false)
  manualStatus     String?   // Admin override: "Cleared", "Not Cleared", or null for auto
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  quiz             Quiz      @relation(fields: [quizId], references: [id])
  user             User      @relation(fields: [userId], references: [id])
}

model SupportMessage {
  id        String   @id @default(uuid())
  userId    String
  quizId    String?
  message   String
  isAdmin   Boolean  @default(false)
  isRead    Boolean  @default(false)
  status    SupportStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  quiz      Quiz?    @relation(fields: [quizId], references: [id])
}

enum SupportStatus {
  PENDING
  RESOLVED
}

model UserTypeAuditLog {
  id           String   @id @default(uuid())
  userId       String
  previousType UserType?
  newType      UserType
  changedAt    DateTime @default(now())
  ipAddress    String?
  userAgent    String?
  user         User     @relation(fields: [userId], references: [id])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String?  // Targeted user (null if global or admin-only)
  type        String   // "EXAM_SUBMITTED", "EXAM_COMPLETED", etc.
  title       String
  message     String
  quizId      String?
  sessionId   String?
  candidateName String?
  candidateEmail String?
  isRead      Boolean  @default(false)
  createdById String?  // Quiz creator ID (for filtering)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User?    @relation(fields: [userId], references: [id])
  
  @@index([userId, isRead])
  @@index([createdById, isRead])
  @@index([createdAt])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CANDIDATE
}

enum UserType {
  AMBASSADOR_RANK_EXAMS
  EXTRAORDINARY_RANK_EXAMS
  PRE_PLENIPOTENTIARY_EXAMS
  PLENIPOTENTIARY_RANK_EXAMS
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([token])
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@index([token])
}
