generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                              String             @id @default(uuid())
  email                           String             @unique
  name                            String
  password                        String
  role                            Role               @default(CANDIDATE)
  userType                        UserType           @default(AMBASSADOR_RANK_EXAMS)
  church                          String?
  emailVerified                   Boolean            @default(false)
  emailVerificationTokenHash      String?
  emailVerificationTokenExpiresAt DateTime?
  emailOtpHash                    String?
  emailOtpExpiresAt               DateTime?
  createdAt                       DateTime           @default(now())
  updatedAt                       DateTime           @updatedAt
  association                     String?
  passwordResetTokenExpiresAt     DateTime?
  passwordResetTokenHash          String?
  uploadedById                    String?
  adminCheckIns                   AttendanceRecord[] @relation("AdminCheckIns")
  attendanceRecords               AttendanceRecord[]
  registeredAttendees             Attendee[]
  auditEntries                    AuditLog[]
  candidateQrs                    CandidateQR[]
  notifications                   Notification[]
  quizzes                         Quiz[]             @relation("QuizCreator")
  sessions                        QuizSession[]
  refreshTokens                   RefreshToken[]
  supportMessages                 SupportMessage[]
  uploadedBy                      User?              @relation("CandidateUploader", fields: [uploadedById], references: [id])
  uploadedCandidates              User[]             @relation("CandidateUploader")
  auditLogs                       UserTypeAuditLog[]

  @@index([uploadedById])
  @@index([role])
  @@index([email])
}

model Question {
  id            String         @id @default(uuid())
  text          String
  optionA       String?
  optionB       String?
  optionC       String?
  optionD       String?
  correctOption String
  questionType  UserType       @default(AMBASSADOR_RANK_EXAMS)
  quizId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  format        QuestionFormat @default(MULTIPLE_CHOICE)
  quiz          Quiz           @relation(fields: [quizId], references: [id])
}

model Quiz {
  id                 String             @id @default(uuid())
  title              String
  duration           Int
  isActive           Boolean            @default(false)
  retakeLimit        Int?               @default(2)
  startDate          DateTime?
  endDate            DateTime?
  createdById        String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  passMark           Float?             @default(50)
  examCode           String?
  enableCandidateQR  Boolean            @default(false)
  enableQRAttendance Boolean            @default(false)
  qrAttendanceCode   String?
  qrCode             String?
  qrCodeExpiresAt    DateTime?
  resultsDisplayMode ResultsDisplayMode @default(DETAILED)
  attendanceRecords  AttendanceRecord[]
  questions          Question[]
  createdBy          User?              @relation("QuizCreator", fields: [createdById], references: [id])
  sessions           QuizSession[]
  supportMessages    SupportMessage[]

  @@index([createdById])
  @@index([isActive])
}

model QuizSession {
  id                   String    @id @default(uuid())
  startTime            DateTime  @default(now())
  endTime              DateTime?
  score                Float?
  answers              Json?
  userId               String
  quizId               String
  resultReleasesAt     DateTime?
  emailSent            Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  manualStatus         String?
  attendanceMethod     String?
  attendanceVerifiedAt DateTime?
  ipAddress            String?
  quiz                 Quiz      @relation(fields: [quizId], references: [id])
  user                 User      @relation(fields: [userId], references: [id])

  @@index([quizId])
  @@index([userId])
  @@index([endTime])
  @@index([score])
  @@index([startTime])
  @@index([userId, quizId])
}

model SupportMessage {
  id        String        @id @default(uuid())
  userId    String
  quizId    String?
  message   String
  isAdmin   Boolean       @default(false)
  isRead    Boolean       @default(false)
  status    SupportStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  quiz      Quiz?         @relation(fields: [quizId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
}

model UserTypeAuditLog {
  id           String    @id @default(uuid())
  userId       String
  previousType UserType?
  newType      UserType
  changedAt    DateTime  @default(now())
  ipAddress    String?
  userAgent    String?
  user         User      @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userId    String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Notification {
  id             String   @id @default(uuid())
  type           String
  title          String
  message        String
  quizId         String?
  sessionId      String?
  candidateName  String?
  candidateEmail String?
  isRead         Boolean  @default(false)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([createdById, isRead])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

model Attendee {
  id                String              @id @default(uuid())
  fullName          String
  church            String?
  email             String?
  phoneNumber       String?
  identityCode      String              @unique
  registeredById    String
  registeredAt      DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  attendanceRecords AttendanceRecord[]
  registeredBy      User                @relation(fields: [registeredById], references: [id])
  identityQr        AttendeeIdentityQR?

  @@index([registeredById])
  @@index([church])
}

model AttendeeIdentityQR {
  id                String             @id @default(uuid())
  attendeeId        String             @unique
  identityCode      String             @unique
  expiresAt         DateTime
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendanceRecords AttendanceRecord[]
  attendee          Attendee           @relation(fields: [attendeeId], references: [id])

  @@index([attendeeId])
  @@index([identityCode])
  @@index([expiresAt])
}

model PublicQuiz {
  id          String           @id @default(uuid())
  title       String
  description String?
  category    String
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  attempts    PublicAttempt[]
  questions   PublicQuestion[]

  @@index([category])
  @@index([isActive])
}

model PublicQuestion {
  id            String                  @id @default(uuid())
  text          String
  optionA       String?
  optionB       String?
  optionC       String?
  optionD       String?
  correctOption String?
  correctAnswer String?
  format        QuestionFormat          @default(MULTIPLE_CHOICE)
  publicQuizId  String
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  publicQuiz    PublicQuiz              @relation(fields: [publicQuizId], references: [id])
  attempts      PublicQuestionAttempt[]

  @@index([publicQuizId])
}

model PublicAttempt {
  id               String                  @id @default(uuid())
  sessionId        String                  @unique
  playerName       String?
  startTime        DateTime                @default(now())
  endTime          DateTime?
  score            Float?
  answers          Json?
  publicQuizId     String
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  publicQuiz       PublicQuiz              @relation(fields: [publicQuizId], references: [id])
  questionAttempts PublicQuestionAttempt[]

  @@index([publicQuizId])
  @@index([sessionId])
}

model PublicQuestionAttempt {
  id               String         @id @default(uuid())
  publicAttemptId  String
  publicQuestionId String
  selectedOption   String?
  textAnswer       String?
  isCorrect        Boolean?
  createdAt        DateTime       @default(now())
  publicAttempt    PublicAttempt  @relation(fields: [publicAttemptId], references: [id])
  publicQuestion   PublicQuestion @relation(fields: [publicQuestionId], references: [id])

  @@index([publicAttemptId])
  @@index([publicQuestionId])
}

model CandidateQR {
  id                String             @id @default(uuid())
  userId            String
  attendanceCode    String             @unique
  expiresAt         DateTime
  isActive          Boolean            @default(true)
  isPermanent       Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendanceRecords AttendanceRecord[]
  user              User               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([attendanceCode])
  @@index([expiresAt])
}

model AttendanceRecord {
  id               String              @id @default(uuid())
  userId           String?
  quizId           String?
  eventName        String?
  checkedInAt      DateTime            @default(now())
  checkedInBy      String
  method           String              @default("QR_SCAN")
  candidateQRId    String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  attendeeId       String?
  attendeeQRId     String?
  attendee         Attendee?           @relation(fields: [attendeeId], references: [id])
  attendeeQR       AttendeeIdentityQR? @relation(fields: [attendeeQRId], references: [id])
  candidateQR      CandidateQR?        @relation(fields: [candidateQRId], references: [id])
  checkedInByAdmin User                @relation("AdminCheckIns", fields: [checkedInBy], references: [id])
  quiz             Quiz?               @relation(fields: [quizId], references: [id])
  user             User?               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([attendeeId])
  @@index([quizId])
  @@index([checkedInBy])
  @@index([checkedInAt])
}

model ManualAttendance {
  id          String   @id @default(uuid())
  fullName    String
  church      String?
  checkInTime DateTime @default(now())
  method      String   @default("MANUAL_ENTRY")
  checkedInBy String?
  eventName   String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([checkInTime])
  @@index([church])
}

enum QuestionFormat {
  MULTIPLE_CHOICE
  FILL_IN_THE_GAP
}

enum ResultsDisplayMode {
  DETAILED
  STUDY
  SCORE_ONLY
}

enum SupportStatus {
  PENDING
  RESOLVED
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CANDIDATE
}

enum UserType {
  AMBASSADOR_RANK_EXAMS
  EXTRAORDINARY_RANK_EXAMS
  PRE_PLENIPOTENTIARY_RANK_EXAMS
  PLENIPOTENTIARY_RANK_EXAMS
}
